#!/usr/bin/env bash
######################################################################
# USRP Unified Installer
# Target: Raspberry Pi OS Desktop / Buster, Bullseye, Bookworm, Trixie
# Fixed target: pi user + Desktop edition only
# Designed by DS5QDR Heonmin Lee in Gimhae, Korea  at 2026.03.21
######################################################################

set -Eeuo pipefail

clear

readonly SCRIPT_NAME="$(basename "$0")"
readonly USER_NAME="pi"
readonly USER_HOME="/home/pi"
readonly CONFIG_DIR="${USER_HOME}/config"
readonly USRP_DIR="${USER_HOME}/USRP"
readonly AUTOSTART_DIR="${USER_HOME}/.config/autostart"
readonly DESKTOP_DIR="${USER_HOME}/Desktop"

readonly USRP_BIN_URL="http://dvsw.ddnsfree.com/program/usrp/usrp"
readonly USRP_BASE_URL="http://dvsw.ddnsfree.com/program/usrp"
readonly ASSET_BASE_URL="http://dvsw.ddnsfree.com"

BOOT_CONFIG=""
CMDLINE_FILE=""
OS_CODENAME=""
OS_VERSION_ID=""
ARCH_BITS=""
USRP_VER=""

log()  { printf '[INFO] %s\n' "$*"; }
warn() { printf '[WARN] %s\n' "$*" >&2; }
err()  { printf '[ERROR] %s\n' "$*" >&2; }

die() {
    err "$*"
    exit 1
}

require_root() {
    [[ "${EUID}" -eq 0 ]] || die "Run as root. Example: sudo bash ${SCRIPT_NAME}"
}

require_pi_user() {
    id "${USER_NAME}" >/dev/null 2>&1 || die "User 'pi' does not exist."
    [[ -d "${USER_HOME}" ]] || die "Home directory not found: ${USER_HOME}"
}

require_desktop_environment() {
    if [[ ! -d "${DESKTOP_DIR}" ]]; then
        die "Desktop environment not detected. This installer is for Raspberry Pi OS Desktop only."
    fi
}

detect_os() {
    [[ -f /etc/os-release ]] || die "/etc/os-release not found."

    # shellcheck disable=SC1091
    source /etc/os-release

    OS_CODENAME="${VERSION_CODENAME:-}"
    OS_VERSION_ID="${VERSION_ID:-}"

    case "${OS_CODENAME}" in
        buster|bullseye)
            BOOT_CONFIG="/boot/config.txt"
            CMDLINE_FILE="/boot/cmdline.txt"
            ;;
        bookworm|trixie)
            BOOT_CONFIG="/boot/firmware/config.txt"
            CMDLINE_FILE="/boot/firmware/cmdline.txt"
            ;;
        *)
            die "Unsupported OS codename: ${OS_CODENAME:-unknown}. Supported: buster, bullseye, bookworm, trixie"
            ;;
    esac

    [[ -f "${BOOT_CONFIG}" ]] || die "Missing boot config: ${BOOT_CONFIG}"
    [[ -f "${CMDLINE_FILE}" ]] || die "Missing cmdline file: ${CMDLINE_FILE}"
}

detect_arch() {
    local dpkg_arch
    dpkg_arch="$(dpkg --print-architecture 2>/dev/null || true)"

    case "${dpkg_arch}" in
        arm64) ARCH_BITS="64" ;;
        armhf|armel) ARCH_BITS="32" ;;
        *)
            if [[ "$(getconf LONG_BIT 2>/dev/null || echo 32)" == "64" ]]; then
                ARCH_BITS="64"
            else
                ARCH_BITS="32"
            fi
            ;;
    esac
}

build_usrp_version() {
    case "${OS_CODENAME}" in
        buster)   USRP_VER="USRP10${ARCH_BITS}" ;;
        bullseye) USRP_VER="USRP11${ARCH_BITS}" ;;
        bookworm) USRP_VER="USRP12${ARCH_BITS}" ;;
        trixie)   USRP_VER="USRP13${ARCH_BITS}" ;;
        *) die "Failed to build USRP version string." ;;
    esac
}

apt_install() {
    apt-get install -y "$@"
}

apt_install_optional() {
    apt-get install -y "$@" >/dev/null 2>&1 || true
}

prepare_system() {
    log "Updating package lists"
    apt-get update

    log "Installing required packages"
    apt_install wget ca-certificates multitail

    log "Installing optional display tools"
    apt_install_optional wlr-randr
    apt_install_optional x11-xserver-utils

    log "Removing optional virtual keyboard packages if present"
    apt-get purge -y squeekboard wvkbd >/dev/null 2>&1 || true

    log "Stopping cups-browsed if present"
    systemctl stop cups-browsed >/dev/null 2>&1 || true
    systemctl disable cups-browsed >/dev/null 2>&1 || true
}

prepare_directories() {
    log "Preparing directories"

    rm -f /usr/local/bin/usrp
    mkdir -p "${CONFIG_DIR}" "${USRP_DIR}" "${AUTOSTART_DIR}" "${DESKTOP_DIR}"

    chown -R "${USER_NAME}:${USER_NAME}" \
        "${CONFIG_DIR}" \
        "${USRP_DIR}" \
        "${AUTOSTART_DIR}" \
        "${DESKTOP_DIR}"
}

download_file() {
    local url="$1"
    local dest="$2"

    mkdir -p "$(dirname "$dest")"
    wget -qO "$dest" "$url"
}

download_if_missing() {
    local url="$1"
    local dest="$2"

    if [[ -f "$dest" ]]; then
        log "Keeping existing file: $dest"
        return
    fi

    download_file "$url" "$dest"
}

download_assets() {
    log "Downloading desktop assets"
    download_file "${ASSET_BASE_URL}/rpi/Desktop/rpi-off.png"         "${CONFIG_DIR}/rpi-off.png"
    download_file "${ASSET_BASE_URL}/rpi/Desktop/rpi-reboot.png"      "${CONFIG_DIR}/rpi-reboot.png"
    download_file "${ASSET_BASE_URL}/program/usrp/USRP.jpg"           "${CONFIG_DIR}/USRP.jpg"

    download_file "${ASSET_BASE_URL}/rpi/Desktop/rpi-off.desktop"     "${DESKTOP_DIR}/rpi-off.desktop"
    download_file "${ASSET_BASE_URL}/rpi/Desktop/rpi-reboot.desktop"  "${DESKTOP_DIR}/rpi-reboot.desktop"
    download_file "${ASSET_BASE_URL}/program/usrp/USRP.desktop"       "${DESKTOP_DIR}/USRP.desktop"

    log "Downloading launcher and USRP binary: ${USRP_VER}"
    download_file "${USRP_BIN_URL}" "/usr/local/bin/usrp"
    download_file "${USRP_BASE_URL}/${USRP_VER}" "${USRP_DIR}/USRP"

    chmod +x /usr/local/bin/usrp "${USRP_DIR}/USRP"

    log "Downloading default config if needed"
    download_if_missing "${ASSET_BASE_URL}/program/usrp/usrp.ini" "${USRP_DIR}/usrp.ini"

    chown -R "${USER_NAME}:${USER_NAME}" "${CONFIG_DIR}" "${USRP_DIR}" "${DESKTOP_DIR}"
}

backup_file_once() {
    local target="$1"
    local backup="${target}.backup"

    [[ -f "$backup" ]] || cp "$target" "$backup"
}

ensure_cmdline_video_arg() {
    local video_arg="video=HDMI-A-1:800x480M@60D"

    if grep -qF "${video_arg}" "${CMDLINE_FILE}"; then
        log "cmdline.txt already contains video parameter"
        return
    fi

    log "Appending video parameter to cmdline.txt"
    backup_file_once "${CMDLINE_FILE}"
    sed -i "1 s|\$| ${video_arg}|" "${CMDLINE_FILE}"
}

create_start_script() {
    local script_path="${CONFIG_DIR}/start_usrp.sh"

    log "Creating start script"

    cat > "${script_path}" <<EOF
#!/usr/bin/env bash
set -Eeuo pipefail

sleep 7

export HOME="${USER_HOME}"
export XDG_RUNTIME_DIR="\${XDG_RUNTIME_DIR:-/run/user/\$(id -u ${USER_NAME})}"

if command -v wlr-randr >/dev/null 2>&1; then
    wlr-randr --output HDMI-A-1 --mode 800x480 >/dev/null 2>&1 || true
fi

if command -v xrandr >/dev/null 2>&1 && [[ -n "\${DISPLAY:-}" ]]; then
    xrandr --output HDMI-1 --mode 800x480 >/dev/null 2>&1 || true
    xrandr --output HDMI-2 --mode 800x480 >/dev/null 2>&1 || true
fi

cd "${USRP_DIR}"
exec ./USRP
EOF

    chmod +x "${script_path}"
    chown "${USER_NAME}:${USER_NAME}" "${script_path}"
}

create_autostart_entry() {
    local desktop_file="${AUTOSTART_DIR}/usrp.desktop"

    log "Creating autostart entry"

    cat > "${desktop_file}" <<EOF
[Desktop Entry]
Type=Application
Name=USRP_Auto
Comment=Start USRP automatically
Exec=${CONFIG_DIR}/start_usrp.sh
Terminal=false
X-GNOME-Autostart-enabled=true
EOF

    chmod 644 "${desktop_file}"
    chown "${USER_NAME}:${USER_NAME}" "${desktop_file}"
}

append_aliases_once() {
    local bashrc="${USER_HOME}/.bashrc"

    [[ -f "${bashrc}" ]] || touch "${bashrc}"

    if grep -q "# --- USRP FULL ALIAS ---" "${bashrc}"; then
        log "Alias block already exists in .bashrc"
        chown "${USER_NAME}:${USER_NAME}" "${bashrc}"
        return
    fi

    log "Appending aliases to .bashrc"

    cat >> "${bashrc}" <<EOF

# --- USRP FULL ALIAS ---
alias cls='clear'
alias naba='sudo nano ~/.bashrc'
alias upba='source ~/.bashrc'
alias bas='sudo nano ~/.bashrc'
alias llba='alias -p'
alias ll='ls -l'
alias ls='ls --color=auto'
alias own='sudo chown ${USER_NAME}:${USER_NAME} '
alias 88='sudo reboot'
alias 66='sudo shutdown -h now'
alias up='sudo apt update && sudo apt upgrade -y'
alias nano='sudo nano -l '
alias ctl='sudo systemctl '
SP=-----------------------------------------------------------------------
alias sys='echo \$SP && hostnamectl && echo \$SP && vcgencmd measure_temp && echo \$SP && cat /sys/firmware/devicetree/base/model && echo && echo \$SP && df -m && echo \$SP && free -m && echo \$SP'
alias s2d="date +'%Y-%m-%d %H:%M:%S' -d "
DT=\$(date -u +%Y-%m-%d.log)
MM=/var/log/mmdvm/MMDVM_Bridge
DV=/var/log/dvswitch
AB=Analog_Bridge.log
alias mt='multitail \$MM-\$DT \$DV/\$AB '
alias rst='sudo systemctl restart mmdvm_bridge analog_bridge '
alias mu='/usr/local/dvs/dvsmu'
alias dv='cd /usr/local/dvs'
alias dvsh='/opt/MMDVM_Bridge/dvswitch.sh '
alias naab='sudo nano /opt/Analog_Bridge/Analog_Bridge.ini'
alias namb='sudo nano /opt/MMDVM_Bridge/MMDVM_Bridge.ini'
alias nadv='sudo nano /opt/MMDVM_Bridge/DVSwitch.ini'
alias naus='cd ${USRP_DIR} && sudo nano usrp.ini'
EOF

    chown "${USER_NAME}:${USER_NAME}" "${bashrc}"
}

print_summary() {
    cat <<EOF

-------------------------------------------------------------
Setup Complete
User        : ${USER_NAME}
Home        : ${USER_HOME}
OS          : ${OS_CODENAME} (${OS_VERSION_ID})
Architecture: ${ARCH_BITS}-bit
USRP_VER    : ${USRP_VER}
BOOT_CONFIG : ${BOOT_CONFIG}
CMDLINE     : ${CMDLINE_FILE}
-------------------------------------------------------------
Reboot recommended: sudo reboot
-------------------------------------------------------------

EOF
}

main() {
    require_root
    require_pi_user
    require_desktop_environment
    detect_os
    detect_arch
    build_usrp_version

    log "Detected OS=${OS_CODENAME}, VERSION=${OS_VERSION_ID}, ARCH=${ARCH_BITS}, USRP=${USRP_VER}"

    prepare_system
    prepare_directories
    download_assets
    ensure_cmdline_video_arg
    create_start_script
    create_autostart_entry
    append_aliases_once
    print_summary
}

main "$@"
